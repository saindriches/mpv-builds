From b5b561f550427ac70be4d9a3d64757306da61fbd Mon Sep 17 00:00:00 2001
From: Rainbaby <rainbaby@outlook.jp>
Date: Tue, 7 Jul 2026 06:54:25 +0900
Subject: [PATCH 2/5] avformat/mmttlv: timestamps, byte index and duration

The demuxer cleared an access unit's recorded offset before its frame
left the parser, so pkt->pos was unset, and it stashed packet flags in
AVCodecParserContext.last_pos; carry pts, dts, pos and flags in the
demuxer's own per-stream state instead. Normalize the absolute NTP
derived timestamps to the first one seen, estimate the duration from a
bounded scan of the file tail, and make read_timestamp probes robust.

Signed-off-by: Rainbaby <rainbaby@outlook.jp>
---
 libavformat/mmtp.c   |  38 ++++++----
 libavformat/mmttlv.c | 168 ++++++++++++++++++++++++++++++++++++++-----
 2 files changed, 175 insertions(+), 31 deletions(-)

diff --git a/libavformat/mmtp.c b/libavformat/mmtp.c
index 145463e..aceaf7c 100644
--- a/libavformat/mmtp.c
+++ b/libavformat/mmtp.c
@@ -152,6 +152,14 @@ struct Streams {
     int64_t  offset;
     int      flags;
 
+    // Timing and origin of the access unit the parser is buffering, handed
+    // over at its first byte and emitted with its frame (the parser is one
+    // access unit deep).
+    int64_t  au_pts;
+    int64_t  au_dts;
+    int64_t  au_pos;
+    int      au_flags;
+
     struct Streams *next;
 };
 
@@ -196,6 +204,7 @@ find_or_allocate_stream(struct MMTPContext *ctx, uint16_t pid)
     streams->stream = stream;
     streams->next   = ctx->streams;
     streams->offset = -1;
+    streams->au_pos = -1;
     ctx->streams    = streams;
     return streams;
 }
@@ -1289,12 +1298,12 @@ static int fill_pts_dts(struct Streams *s)
     if (s->au_count >= ext_desc->num_of_au)
         return AVERROR_INVALIDDATA;
 
-    s->parser->dts = ptime - ext_desc->decoding_time_offset;
+    s->au_dts = ptime - ext_desc->decoding_time_offset;
 
     for (j = 0; j < s->au_count; ++j)
-        s->parser->dts += ext_desc->au[j].pts_offset;
+        s->au_dts += ext_desc->au[j].pts_offset;
 
-    s->parser->pts = s->parser->dts + ext_desc->au[s->au_count].dts_pts_offset;
+    s->au_pts = s->au_dts + ext_desc->au[s->au_count].dts_pts_offset;
 
     ++s->au_count;
     return 0;
@@ -1376,7 +1385,6 @@ emit_packet(MMTPContext *ctx, struct Streams *st, uint8_t *data, int size)
     if (st->parser == NULL) {
         st->parser = av_parser_init(st->stream->codecpar->codec_id);
         if (st->parser == NULL) return AVERROR(ENOMEM);
-        st->parser->last_pos = 0;
     }
 
     while (size > 0) {
@@ -1384,12 +1392,14 @@ emit_packet(MMTPContext *ctx, struct Streams *st, uint8_t *data, int size)
             if ((err = fill_pts_dts(st)) < 0)
                 return err;
             st->parser->fetch_timestamp = false;
-            st->parser->pos             = st->offset;
-            // use last_pos to store flags
-            st->parser->last_pos        = st->flags;
+            st->au_pos   = st->offset;
+            st->au_flags = st->flags;
+            // Clear only after the hand-over: parse_mpu records the next
+            // access unit's offset before the parser reaches this frame
+            // boundary.
+            st->offset = -1;
+            st->flags  = 0;
         }
-        st->offset = -1;
-        st->flags  = 0;
 
         consumed = av_parser_parse2(
             st->parser, ffstream(st->stream)->avctx,
@@ -1419,11 +1429,11 @@ emit_packet(MMTPContext *ctx, struct Streams *st, uint8_t *data, int size)
         if ((err = av_packet_make_refcounted(ctx->pkt)) < 0)
             return err;
 
-        ctx->pkt->pos          = st->parser->pos;
-        ctx->pkt->pts          = st->parser->pts;
-        ctx->pkt->dts          = st->parser->dts;
+        ctx->pkt->pos          = st->au_pos;
+        ctx->pkt->pts          = st->au_pts;
+        ctx->pkt->dts          = st->au_dts;
         ctx->pkt->stream_index = st->stream->index;
-        ctx->pkt->flags        = st->parser->last_pos;
+        ctx->pkt->flags        = st->au_flags;
         if (st->parser->key_frame == 1)
             ctx->pkt->flags |= AV_PKT_FLAG_KEY;
     }
@@ -1697,6 +1707,8 @@ void ff_mmtp_reset_state(MMTPContext *ctx)
         streams->au_count             = 0;
         streams->flags                = 0;
         streams->offset               = -1;
+        streams->au_flags             = 0;
+        streams->au_pos               = -1;
     }
 }
 
diff --git a/libavformat/mmttlv.c b/libavformat/mmttlv.c
index db769fc..727c7a3 100644
--- a/libavformat/mmttlv.c
+++ b/libavformat/mmttlv.c
@@ -105,6 +105,8 @@ struct MMTTLVContext {
 
     size_t  cap;
     uint8_t *buf;
+
+    int64_t first_pts;
 };
 
 static int mmttlv_read_ipv6_packet(
@@ -314,16 +316,84 @@ static int mmttlv_read_packet(AVFormatContext *s, AVPacket *pkt)
 
     switch (header[1]) {
     case IPV6_PACKET:
-        return mmttlv_read_ipv6_packet(ctx, s, pkt, ctx->buf, size);
+        err = mmttlv_read_ipv6_packet(ctx, s, pkt, ctx->buf, size);
+        break;
     case HEADER_COMPRESSED_IP_PACKET:
-        return mmttlv_read_compressed_ip_packet(ctx, s, pkt, ctx->buf, size);
+        err = mmttlv_read_compressed_ip_packet(ctx, s, pkt, ctx->buf, size);
+        break;
     case TRANSMISSION_CONTROL_PACKET:
-        return pkt == NULL ? 0 : FFERROR_REDO;
+        err = pkt == NULL ? 0 : FFERROR_REDO;
+        break;
     default:
         av_log(s, AV_LOG_INFO,
                "unsupported TLV packet type 0x%02x\n", header[1]);
-        return pkt == NULL ? 0 : FFERROR_REDO;
+        err = pkt == NULL ? 0 : FFERROR_REDO;
+        break;
     }
+
+    if (err >= 0 && pkt != NULL) {
+        // MMT presentation times are absolute (NTP derived); anchor them on
+        // the first timestamped packet so seekable and streamed inputs share
+        // one origin.
+        if (ctx->first_pts == AV_NOPTS_VALUE && pkt->pts != AV_NOPTS_VALUE)
+            ctx->first_pts = pkt->pts;
+        if (ctx->first_pts != AV_NOPTS_VALUE) {
+            if (pkt->pts != AV_NOPTS_VALUE)
+                pkt->pts -= ctx->first_pts;
+            if (pkt->dts != AV_NOPTS_VALUE)
+                pkt->dts -= ctx->first_pts;
+        }
+    }
+
+    return err;
+}
+
+// Scan [pos, pos_limit) for the last timestamped packet, for the duration
+// estimate at open.
+static int64_t mmttlv_scan_last_ts(AVFormatContext *s, int64_t pos,
+                                   int64_t pos_limit, int *stream_index)
+{
+    struct MMTTLVContext *ctx = s->priv_data;
+    size_t   saved_resync     = ctx->resync_size;
+    int64_t  last_ts          = AV_NOPTS_VALUE;
+    AVPacket *pkt;
+    int      ret;
+
+    pkt = av_packet_alloc();
+    if (pkt == NULL)
+        return AV_NOPTS_VALUE;
+
+    if (avio_seek(s->pb, pos, SEEK_SET) < 0) {
+        av_packet_free(&pkt);
+        return AV_NOPTS_VALUE;
+    }
+
+    ctx->last_pos    = -1; // force resync
+    // A blind landing can fall inside a video TLV packet, which can exceed
+    // the default window.
+    ctx->resync_size = 65536 + 4096;
+
+    for (;;) {
+        int64_t here = avio_tell(s->pb);
+        if (here < 0 || here >= pos_limit)
+            break;
+        ret = mmttlv_read_packet(s, pkt);
+        if (ret == AVERROR_EOF)
+            break;
+        if (ret >= 0) {
+            if (pkt->pts != AV_NOPTS_VALUE) {
+                last_ts       = pkt->pts;
+                *stream_index = pkt->stream_index;
+            }
+            av_packet_unref(pkt);
+        } else if (avio_tell(s->pb) <= here) {
+            break; // a hard error without progress; the scan is best effort
+        }
+    }
+
+    av_packet_free(&pkt);
+    ctx->resync_size = saved_resync;
+    return last_ts;
 }
 
 static int mmttlv_read_header(AVFormatContext *s)
@@ -331,6 +401,9 @@ static int mmttlv_read_header(AVFormatContext *s)
     int64_t              pos;
     int64_t              allow = s->probesize;
     struct MMTTLVContext *ctx  = s->priv_data;
+    int64_t              file_size;
+    AVPacket             *pkt;
+    int                  ret;
 
     ctx->last_pos = avio_tell(s->pb);
     if (ctx->last_pos < 0)
@@ -338,14 +411,12 @@ static int mmttlv_read_header(AVFormatContext *s)
     ctx->last_pos -= 1; // force resync
 
     ctx->resync_size = 4096;
+    ctx->first_pts   = AV_NOPTS_VALUE;
     s->ctx_flags |= AVFMTCTX_NOHEADER;
 
     if (!s->pb->seekable)
         return 0;
 
-    if ((pos = avio_tell(s->pb)) < 0)
-        return (int) pos;
-
     while (s->nb_streams <= 0 && allow > 0) {
         const int64_t cur = ctx->last_pos;
         const int     err = mmttlv_read_packet(s, NULL);
@@ -353,13 +424,47 @@ static int mmttlv_read_header(AVFormatContext *s)
         allow -= ctx->last_pos - cur;
     }
 
-    ctx->last_pos = avio_tell(s->pb);
-    if (ctx->last_pos < 0)
-        return (int) ctx->last_pos;
+    pkt = av_packet_alloc();
+    if (pkt == NULL)
+        return AVERROR(ENOMEM);
+
+    // Read on until the first timestamped packet; mmttlv_read_packet()
+    // anchors first_pts on it.
+    while (ctx->first_pts == AV_NOPTS_VALUE) {
+        ret = mmttlv_read_packet(s, pkt);
+        if (ret >= 0) {
+            av_packet_unref(pkt);
+        } else if (ret == AVERROR_EOF) {
+            break;
+        } else if (ret != FFERROR_REDO) {
+            av_packet_free(&pkt);
+            return ret;
+        }
+    }
+    av_packet_free(&pkt);
+
+    if (ctx->first_pts != AV_NOPTS_VALUE && (file_size = avio_size(s->pb)) > 0) {
+        // Estimate the duration from the last MPU timestamp; scanning only
+        // the trailing 32 MB keeps open() cheap on multi-GB files.
+        int64_t scan_pos = FFMAX(0, file_size - 32 * 1024 * 1024);
+        int     sidx     = -1;
+        int64_t last_ts  = mmttlv_scan_last_ts(s, scan_pos, file_size, &sidx);
+        if (last_ts != AV_NOPTS_VALUE && sidx >= 0 && sidx < s->nb_streams) {
+            AVStream *st = s->streams[sidx];
+            if (st->time_base.den > 0)
+                s->duration = av_rescale_q(last_ts, st->time_base,
+                                           AV_TIME_BASE_Q);
+        }
+    }
 
-    if ((pos = avio_seek(s->pb, pos, SEEK_SET)) < 0)
+    if ((pos = avio_seek(s->pb, 0, SEEK_SET)) < 0)
         return (int) pos;
 
+    ctx->last_pos = -1; // force resync and a parser state reset
+    for (struct Program *program = ctx->programs;
+         program != NULL; program = program->next)
+        ff_mmtp_reset_state(program->mmtp);
+
     return 0;
 }
 
@@ -379,14 +484,22 @@ static int mmttlv_read_close(AVFormatContext *ctx)
     return 0;
 }
 
+// Timestamp of the next access unit of stream_index at or after *pos.
 static int64_t mmttlv_read_timestamp(
     struct AVFormatContext *s, int stream_index,
     int64_t *pos, int64_t pos_limit)
 {
     struct MMTTLVContext *ctx = s->priv_data;
+    size_t  saved_resync = ctx->resync_size;
+    int64_t result       = AV_NOPTS_VALUE;
 
     if ((*pos = avio_seek(s->pb, *pos, SEEK_SET)) < 0)
-        return (int) *pos;
+        return AV_NOPTS_VALUE;
+    // A probe can land inside a video TLV packet, which can exceed the
+    // default resync window; widen it, and reset state so probes are
+    // independent of each other.
+    ctx->resync_size = 65536 + 4096;
+    ctx->last_pos    = -1;
 
     while (pos_limit > 0) {
         AVPacket      packet = {0};
@@ -395,17 +508,36 @@ static int64_t mmttlv_read_timestamp(
         const int64_t off    = packet.pos;
         const int     sid    = packet.stream_index;
         av_packet_unref(&packet);
-        if (err >= 0 && (stream_index < 0 || sid == stream_index)) {
-            *pos = off;
-            return ts;
+
+        if (err == AVERROR_EOF)
+            break;
+
+        if (err >= 0 && ts != AV_NOPTS_VALUE &&
+            (stream_index < 0 || sid == stream_index)) {
+            *pos   = off;
+            result = ts;
+            break;
         }
+
+        if (err < 0 && err != FFERROR_REDO) {
+            // a bad spot: advance one byte and resync, staying in budget
+            const int64_t here = avio_tell(s->pb);
+            if (here < 0)
+                break;
+            pos_limit -= (here + 1) - *pos;
+            *pos = here + 1;
+            if (avio_seek(s->pb, *pos, SEEK_SET) < 0)
+                break;
+            ctx->last_pos = -1;
+            continue;
+        }
+
         pos_limit -= ctx->last_pos - *pos;
         *pos = ctx->last_pos;
-        if (err < 0 && err != FFERROR_REDO)
-            return AV_NOPTS_VALUE;
     }
 
-    return AV_NOPTS_VALUE;
+    ctx->resync_size = saved_resync;
+    return result;
 }
 
 #if CONFIG_MMTTLV_DEMUXER
