From 5f6cf286dd9b6912654bad1beb3e241fa131c582 Mon Sep 17 00:00:00 2001
From: Rainbaby <rainbaby@outlook.jp>
Date: Tue, 7 Jul 2026 06:58:33 +0900
Subject: [PATCH 5/5] avformat/mmttlv: byte-estimate seek with probe refinement

A timestamp binary search re-acquires signaling and reassembles a
whole access unit per probe, reading tens of MB on 4K/8K content. MMT
is near constant bitrate: estimate the byte position linearly, probe
the timestamp found there, correct by the error and bisect once the
target is bracketed; across a timestamp discontinuity (cut content)
land on the earliest probed unit past the target.

Signed-off-by: Rainbaby <rainbaby@outlook.jp>
---
 libavformat/mmttlv.c | 80 ++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 80 insertions(+)

diff --git a/libavformat/mmttlv.c b/libavformat/mmttlv.c
index 727c7a3..b25b891 100644
--- a/libavformat/mmttlv.c
+++ b/libavformat/mmttlv.c
@@ -23,6 +23,7 @@
 
 #include "libavutil/mem.h"
 #include "libavutil/intreadwrite.h"
+#include "libavutil/mathematics.h"
 #include "avformat.h"
 #include "avio_internal.h"
 #include "demux.h"
@@ -540,6 +541,84 @@ static int64_t mmttlv_read_timestamp(
     return result;
 }
 
+// Seek by a byte-position estimate. A timestamp binary search re-acquires
+// signaling and reassembles a whole access unit per probe, which on 4K/8K
+// content reads tens of MB and collapses; MMT runs at close to constant
+// bitrate, so map the target time onto the file linearly and refine.
+static int mmttlv_read_seek(AVFormatContext *s, int stream_index,
+                            int64_t timestamp, int flags)
+{
+    struct MMTTLVContext *ctx = s->priv_data;
+    AVStream             *st  = s->streams[stream_index];
+    int64_t file_size = avio_size(s->pb);
+    int64_t ts_us, bytes_per_sec, pos;
+
+    if (file_size <= 0 || s->duration <= 0)
+        return AVERROR(ENOSYS);
+
+    ts_us         = av_rescale_q(timestamp, st->time_base, AV_TIME_BASE_Q);
+    ts_us         = av_clip64(ts_us, 0, s->duration);
+    bytes_per_sec = av_rescale(file_size, AV_TIME_BASE, s->duration);
+    pos           = av_rescale(ts_us, file_size, s->duration) -
+                    2 * bytes_per_sec;
+    pos           = av_clip64(pos, 0, file_size - 1);
+
+    // The linear estimate can be minutes off on VBR content (stripped
+    // stuffing). Probe the timestamp actually found at the estimate and
+    // correct by the error, a few rounds; accept a landing 2 to 6 s before
+    // the target and seek to that access unit's own offset. Only a timestamp
+    // discontinuity (cut content) defeats convergence, with probes
+    // oscillating around the gap; land on the earliest probed unit past the
+    // target then.
+    {
+        int64_t lo = -1, hi = -1, hi_pos = -1;
+        int     i, converged = 0;
+        for (i = 0; i < 8; i++) {
+            int64_t p  = av_clip64(pos, 0, file_size - 1);
+            int64_t ts = mmttlv_read_timestamp(s, stream_index, &p, INT64_MAX);
+            int64_t ts2, diff;
+            if (ts == AV_NOPTS_VALUE) {
+                // beyond the last timestamped unit: step back and retry
+                pos -= 30 * bytes_per_sec;
+                if (pos < 0) {
+                    pos = 0;
+                    converged = 1;
+                    break;
+                }
+                continue;
+            }
+            ts2  = av_rescale_q(ts, st->time_base, AV_TIME_BASE_Q);
+            diff = ts_us - 2 * AV_TIME_BASE - ts2;
+            if (diff >= 0 && diff <= 4 * AV_TIME_BASE) {
+                pos = p;
+                converged = 1;
+                break;
+            }
+            if (diff > 0) {
+                if (p > lo)
+                    lo = p;
+            } else if (hi < 0 || p < hi) {
+                hi     = p;
+                hi_pos = p;
+            }
+            if (lo >= 0 && hi >= 0 && hi - lo > 1)
+                pos = lo + (hi - lo) / 2; // bracketed: bisect toward the edge
+            else
+                pos = p + av_rescale(diff, bytes_per_sec, AV_TIME_BASE);
+            pos = av_clip64(pos, 0, file_size - 1);
+        }
+        if (!converged && hi_pos >= 0)
+            pos = hi_pos;
+    }
+
+    if ((pos = avio_seek(s->pb, pos, SEEK_SET)) < 0)
+        return (int) pos;
+    ctx->last_pos    = -1; // force resync and a parser state reset
+    // reach the next boundary even from inside a maximum-size packet
+    ctx->resync_size = 65536 + 4096;
+    return 0;
+}
+
 #if CONFIG_MMTTLV_DEMUXER
 const FFInputFormat ff_mmttlv_demuxer = {
     .p.name         = "mmttlv",
@@ -553,5 +632,6 @@ const FFInputFormat ff_mmttlv_demuxer = {
     .read_packet    = mmttlv_read_packet,
     .read_close     = mmttlv_read_close,
     .read_timestamp = mmttlv_read_timestamp,
+    .read_seek      = mmttlv_read_seek,
 };
 #endif
