From a17a4ad3e5e76214eac6ddfba19d4168ec3619fb Mon Sep 17 00:00:00 2001
From: Rainbaby <rainbaby@outlook.jp>
Date: Mon, 6 Jul 2026 19:48:20 +0900
Subject: [PATCH 6/8] avformat/mmttlv: fill audio channels and rate from
 MH-audio-component

The descriptor carries the authoritative channel count (audio_mode, STD-B60
Table 7-60) and sample rate. Seed codecpar from it: the LATM ES header can
under-report (a 5.1 program whose config declares stereo), leaving the stream
at "0 channels" until probed, while the signaling is reliable.

Signed-off-by: Rainbaby <rainbaby@outlook.jp>
---
 libavformat/mmtp.c | 56 +++++++++++++++++++++++++++++++++++++++++-----
 1 file changed, 50 insertions(+), 6 deletions(-)

diff --git a/libavformat/mmtp.c b/libavformat/mmtp.c
index 8f45c7b..6d9aa84 100644
--- a/libavformat/mmtp.c
+++ b/libavformat/mmtp.c
@@ -24,6 +24,7 @@
 #include "libavcodec/bytestream.h"
 #include "libavcodec/avcodec.h"
 #include "libavutil/avassert.h"
+#include "libavutil/channel_layout.h"
 #include "libavutil/mem.h"
 #include "demux.h"
 #include "internal.h"
@@ -270,6 +271,33 @@ parse_video_component_descriptor(AVStream *stream, GetByteContext *gbc)
     return av_dict_set(&stream->metadata, "language", language_code, 0);
 }
 
+// ARIB STD-B60 Table 7-60 audio_mode -> channel count. 0 leaves it to the ES.
+static int mmt_audio_mode_channels(int mode)
+{
+    switch (mode) {
+    case 0x01: return 1;   // 1/0
+    case 0x02: return 2;   // 1/0 + 1/0 dual mono
+    case 0x03: return 2;   // 2/0
+    case 0x05: return 3;   // 3/0
+    case 0x07: return 4;   // 3/1
+    case 0x08: return 5;   // 3/2
+    case 0x09: return 6;   // 3/2 + LFE (5.1)
+    case 0x0c: return 8;   // 5/2.1 (7.1)
+    case 0x11: return 24;  // 22.2
+    default:   return 0;
+    }
+}
+
+// MH-audio-component sampling_rate 3-bit code -> Hz. 0 leaves it to the ES.
+static int mmt_audio_sampling_rate(int code)
+{
+    switch (code) {
+    case 0x1: return 16000; case 0x2: return 22050; case 0x3: return 24000;
+    case 0x5: return 32000; case 0x6: return 44100; case 0x7: return 48000;
+    default:  return 0;
+    }
+}
+
 static int
 parse_mh_audio_component_descriptor(AVStream *stream, GetByteContext *gbc)
 {
@@ -280,6 +308,8 @@ parse_mh_audio_component_descriptor(AVStream *stream, GetByteContext *gbc)
     const uint8_t *text     = NULL;
     int           text_len  = 0;
     int           main_audio = 0;
+    int           audio_mode = 0;
+    int           sampling_code = 0;
 
     if (bytestream2_get_bytes_left(gbc) < (16 + 8) / 8)
         return AVERROR_INVALIDDATA;
@@ -303,12 +333,11 @@ parse_mh_audio_component_descriptor(AVStream *stream, GetByteContext *gbc)
         byte           = bytestream2_get_byteu(&ngbc);
         stream_content = byte & 0b1111;
 
-        /*
-         * skip:
-         * - component_type
-         * - component_tag
-         */
-        bytestream2_skipu(&ngbc, 3);
+        // component_type: dialog<<7 | handicapped(2)<<5 | audio_mode(5)
+        audio_mode = bytestream2_get_byteu(&ngbc) & 0x1F;
+
+        // skip: component_tag
+        bytestream2_skipu(&ngbc, 2);
         stream_type = bytestream2_get_byteu(&ngbc);
 
         // skip: simulcast_group_tag
@@ -317,6 +346,7 @@ parse_mh_audio_component_descriptor(AVStream *stream, GetByteContext *gbc)
         byte                  = bytestream2_get_byteu(&ngbc);
         ES_multi_lingual_flag = byte >> 7;
         main_audio            = (byte >> 6) & 1;
+        sampling_code         = (byte >> 1) & 0x07;
 
         bytestream2_get_bufferu(&ngbc, language_code, 3);
         language_code[3] = '\0';
@@ -351,6 +381,20 @@ parse_mh_audio_component_descriptor(AVStream *stream, GetByteContext *gbc)
         break;
     }
 
+    // The signaling carries the authoritative channel count and sample rate; the LATM
+    // ES header can under-report (e.g. a 5.1 program whose config declares stereo), so
+    // seed them here and let the ES refine only what it leaves unset.
+    {
+        int channels = mmt_audio_mode_channels(audio_mode);
+        int rate      = mmt_audio_sampling_rate(sampling_code);
+        if (channels) {
+            av_channel_layout_uninit(&stream->codecpar->ch_layout);
+            av_channel_layout_default(&stream->codecpar->ch_layout, channels);
+        }
+        if (rate)
+            stream->codecpar->sample_rate = rate;
+    }
+
     if (main_audio)
         stream->disposition |= AV_DISPOSITION_DEFAULT;
     if (text_len > 0) {
-- 
