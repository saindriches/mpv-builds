From 0488a01488d71d03ec99bfb5f10d9625c82eb8a2 Mon Sep 17 00:00:00 2001
From: Rainbaby <rainbaby@outlook.jp>
Date: Tue, 7 Jul 2026 06:08:15 +0900
Subject: [PATCH 4/4] avformat/mmttlv: survive a blind landing after a seek

A byte-estimate seek can land inside a video TLV packet (up to 64 KB), but
the resync hunted only 4 KB, accepted any 0x7F with a chained 0x7F as a
header (coded HEVC hits that often), and returned a hard error when the
window ran out. Players that cap consecutive read errors (mpv allows ~10)
then turn one bad landing into EOF.

Require a defined packet_type on resync candidates, widen the post-seek
hunt window past the largest packet, and on an exhausted hunt keep moving
with FFERROR_REDO (bounded) instead of failing the read.

Signed-off-by: Rainbaby <rainbaby@outlook.jp>
---
 libavformat/mmttlv.c | 26 ++++++++++++++++++++++----
 1 file changed, 22 insertions(+), 4 deletions(-)

diff --git a/libavformat/mmttlv.c b/libavformat/mmttlv.c
index 95870fa..140a7ad 100644
--- a/libavformat/mmttlv.c
+++ b/libavformat/mmttlv.c
@@ -102,6 +102,7 @@ struct MMTTLVContext {
 
     int64_t last_pos;
     size_t  resync_size;
+    int     resync_fails;   // consecutive exhausted hunts; bounds the REDO retries
 
     size_t  cap;
     uint8_t *buf;
@@ -199,6 +200,15 @@ static int mmttlv_read_compressed_ip_packet(
     return ff_mmtp_parse_packet(program->mmtp, s, pkt, buf, size);
 }
 
+// 0x7F occurs freely inside coded payloads; a resync candidate must also carry a
+// defined packet_type or the hunt latches onto false headers.
+static int mmttlv_valid_type(uint8_t t)
+{
+    return t == IPV4_PACKET || t == IPV6_PACKET ||
+           t == HEADER_COMPRESSED_IP_PACKET ||
+           t == TRANSMISSION_CONTROL_PACKET || t == NULL_PACKET;
+}
+
 static int mmttlv_read_packet(AVFormatContext *s, AVPacket *pkt)
 {
     uint8_t              header[4];
@@ -221,7 +231,7 @@ static int mmttlv_read_packet(AVFormatContext *s, AVPacket *pkt)
             if ((err = avio_read(s->pb, header, 4)) < 0)
                 return avio_feof(s->pb) ? AVERROR_EOF : err;
 
-            if (header[0] != HEADER_BYTE) {
+            if (header[0] != HEADER_BYTE || !mmttlv_valid_type(header[1])) {
                 if ((pos = avio_seek(s->pb, -3, SEEK_CUR)) < 0)
                     return (int) pos;
                 continue;
@@ -253,9 +263,15 @@ static int mmttlv_read_packet(AVFormatContext *s, AVPacket *pkt)
                 s->pb, -(int64_t) (size) - 1 - 3, SEEK_CUR)) < 0)
                 return (int) pos;
         }
+        // Window exhausted. The position has advanced by the whole hunt, so retrying makes
+        // progress; a hard error here lets a caller's error cap turn one bad landing into EOF
+        // (mpv treats ~10 consecutive errors as fatal). Bounded by the give-up below.
+        if (++ctx->resync_fails <= 32)
+            return FFERROR_REDO;
         return AVERROR_INVALIDDATA;
 
         success:
+        ctx->resync_fails = 0;
         ctx->last_pos = pos;
 
         for (struct Program *program = ctx->programs;
@@ -386,8 +402,9 @@ static int mmttlv_read_header(AVFormatContext *s)
         return (int) ctx->last_pos;
     ctx->last_pos -= 1; // force resync
 
-    ctx->resync_size = 4096;
-    ctx->first_pts   = AV_NOPTS_VALUE;
+    ctx->resync_size  = 4096;
+    ctx->resync_fails = 0;
+    ctx->first_pts    = AV_NOPTS_VALUE;
     s->ctx_flags |= AVFMTCTX_NOHEADER;
 
     if (!s->pb->seekable)
@@ -545,7 +562,8 @@ static int mmttlv_read_seek(AVFormatContext *s, int stream_index,
 
     if ((pos = avio_seek(s->pb, pos, SEEK_SET)) < 0)
         return (int) pos;
-    ctx->last_pos = -1; // force resync + state reset at the new position
+    ctx->last_pos    = -1; // force resync + state reset at the new position
+    ctx->resync_size = 65536 + 4096; // reach the next boundary from inside a max-size packet
     return 0;
 }
 
