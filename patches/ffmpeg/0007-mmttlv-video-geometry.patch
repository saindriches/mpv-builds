From 864420f7a4b9b237f180e5148b11c5d1000df6df Mon Sep 17 00:00:00 2001
From: Rainbaby <rainbaby@outlook.jp>
Date: Mon, 6 Jul 2026 19:52:49 +0900
Subject: [PATCH 7/8] avformat/mmttlv: seed video geometry and colour from
 MH-video-component

Parse video_resolution, aspect_ratio, frame_rate and transfer_characteristics
(STD-B60 Tables 7-47/7-51) instead of skipping them, seeding width, height,
frame rate and BT.2020 HLG/PQ colour. The ES overrides what it carries; this
fills its gaps (and scrambled streams that never reach the ES).

Signed-off-by: Rainbaby <rainbaby@outlook.jp>
---
 libavformat/mmtp.c | 73 ++++++++++++++++++++++++++++++++++++----------
 1 file changed, 58 insertions(+), 15 deletions(-)

diff --git a/libavformat/mmtp.c b/libavformat/mmtp.c
index 6d9aa84..db1a26b 100644
--- a/libavformat/mmtp.c
+++ b/libavformat/mmtp.c
@@ -230,6 +230,29 @@ enum {
     MH_SHORT_EVENT_DESCRIPTOR         = 0xF001,
 };
 
+// MH-video-component video_resolution code -> luma height. 0 leaves it to the ES.
+static int mmt_video_height(int code)
+{
+    switch (code) {
+    case 1: return 180;  case 2: return 240;  case 3: return 480;  case 4: return 720;
+    case 5: return 1080; case 6: return 2160; case 7: return 4320; default: return 0;
+    }
+}
+
+// MH-video-component video_frame_rate code -> rate. 0/1 den means "unknown".
+static AVRational mmt_video_frame_rate(int code)
+{
+    switch (code) {
+    case 1:  return (AVRational){ 15, 1 };       case 2:  return (AVRational){ 24000, 1001 };
+    case 3:  return (AVRational){ 24, 1 };        case 4:  return (AVRational){ 25, 1 };
+    case 5:  return (AVRational){ 30000, 1001 };  case 6:  return (AVRational){ 30, 1 };
+    case 7:  return (AVRational){ 50, 1 };        case 8:  return (AVRational){ 60000, 1001 };
+    case 9:  return (AVRational){ 60, 1 };        case 10: return (AVRational){ 100, 1 };
+    case 11: return (AVRational){ 120000, 1001 }; case 12: return (AVRational){ 120, 1 };
+    default: return (AVRational){ 0, 1 };
+    }
+}
+
 static int
 parse_video_component_descriptor(AVStream *stream, GetByteContext *gbc)
 {
@@ -246,24 +269,44 @@ parse_video_component_descriptor(AVStream *stream, GetByteContext *gbc)
         return AVERROR_INVALIDDATA;
     {
         GetByteContext ngbc;
-        bytestream2_init(&ngbc, gbc->buffer, descriptor_length);
-        /*
-         * skip:
-         * - video_resolution
-         * - video_aspect_ratio
-         * - video_scan_flag
-         * - reserved
-         * - video_frame_rate
-         * - component_tag
-         * - video_transfer_characteristics
-         * - reserved
-         */
-        bytestream2_skip(&ngbc, (4 + 4 + 1 + 2 + 5 + 16 + 4 + 4) / 8);
-
-        if (bytestream2_get_bytes_left(&ngbc) < 3)
+        int     res, aspect, frame_rate_code, transfer;
+        uint8_t b0, b1;
+
+        // resolution|aspect, scan|reserved|frame_rate, component_tag(2), transfer|reserved, lang(3)
+        if (descriptor_length < 8)
             return AVERROR_INVALIDDATA;
+        bytestream2_init(&ngbc, gbc->buffer, descriptor_length);
+
+        b0              = bytestream2_get_byteu(&ngbc);
+        b1              = bytestream2_get_byteu(&ngbc);
+        res             = b0 >> 4;
+        aspect          = b0 & 0x0F;
+        frame_rate_code = b1 & 0x1F;
+        bytestream2_skipu(&ngbc, 2);
+        transfer        = bytestream2_get_byteu(&ngbc) >> 4;
         bytestream2_get_bufferu(&ngbc, language_code, 3);
         language_code[3] = '\0';
+
+        if (stream) {
+            int        h  = mmt_video_height(res);
+            AVRational fr = mmt_video_frame_rate(frame_rate_code);
+            // Seed geometry and colour from signaling; the ES overrides what it carries.
+            if (h && stream->codecpar->height <= 0) {
+                stream->codecpar->height = h;
+                stream->codecpar->width  = aspect == 1 ? h * 4 / 3 : h * 16 / 9;
+            }
+            if (fr.num && !stream->avg_frame_rate.num)
+                stream->avg_frame_rate = stream->r_frame_rate = fr;
+            // STD-B60 Table 7-51: transfer 3/4/5 (BT.2020/PQ/HLG) imply BT.2020 colour.
+            if (transfer >= 3 && transfer <= 5 &&
+                stream->codecpar->color_trc <= AVCOL_TRC_UNSPECIFIED) {
+                stream->codecpar->color_trc       = transfer == 5 ? AVCOL_TRC_ARIB_STD_B67 :
+                                                    transfer == 4 ? AVCOL_TRC_SMPTE2084    :
+                                                                    AVCOL_TRC_BT2020_10;
+                stream->codecpar->color_primaries = AVCOL_PRI_BT2020;
+                stream->codecpar->color_space     = AVCOL_SPC_BT2020_NCL;
+            }
+        }
     }
     bytestream2_skipu(gbc, descriptor_length);
 
-- 
