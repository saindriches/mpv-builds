From a87f7a4b7fb9416120b8c65c0d05bb48efbe2d96 Mon Sep 17 00:00:00 2001
From: Rainbaby <rainbaby@outlook.jp>
Date: Tue, 7 Jul 2026 06:51:58 +0900
Subject: [PATCH 1/5] avformat/mmttlv: harden parsing and resync

Fix av_malloc error codes and an unchecked parse context, pad MFU
payloads for ff_combine_frame, bound short descriptor loops, and keep
a non-conformant multi-frame MFU from aborting on an assert. Resync
accepts a candidate only when three length-chained headers carry
defined TLV packet types, skips unknown types, and an exhausted hunt
returns a bounded FFERROR_REDO instead of ending playback.

Signed-off-by: Rainbaby <rainbaby@outlook.jp>
---
 libavformat/mmtp.c   | 35 ++++++++++++----
 libavformat/mmttlv.c | 96 +++++++++++++++++++++++++++++++-------------
 2 files changed, 95 insertions(+), 36 deletions(-)

diff --git a/libavformat/mmtp.c b/libavformat/mmtp.c
index 29f6323..145463e 100644
--- a/libavformat/mmtp.c
+++ b/libavformat/mmtp.c
@@ -714,11 +714,13 @@ static int parse_mh_short_event_descriptor(
         GetByteContext ngbc;
         bytestream2_init(&ngbc, gbc->buffer, descriptor_length);
 
-        bytestream2_get_buffer(&ngbc, language_code, 3);
+        if (bytestream2_get_bytes_left(&ngbc) < 4)
+            return AVERROR_INVALIDDATA;
+        bytestream2_get_bufferu(&ngbc, language_code, 3);
         language_code[3] = '\0';
 
-        event_name_length = bytestream2_get_byte(&ngbc);
-        if (bytestream2_get_bytes_left(&ngbc) < event_name_length)
+        event_name_length = bytestream2_get_byteu(&ngbc);
+        if (bytestream2_get_bytes_left(&ngbc) < event_name_length + 2)
             return AVERROR_INVALIDDATA;
         event_name = av_strndup(ngbc.buffer, event_name_length);
         bytestream2_skipu(&ngbc, event_name_length);
@@ -952,10 +954,12 @@ static int parse_mh_eit_table(MMTPContext *ctx, GetByteContext *gbc)
 
         bytestream2_skip(&ngbc, (16 + 2 + 5 + 1 + 8 + 8 + 16 + 16 + 8 + 8) / 8);
 
-        while (bytestream2_get_bytes_left(&ngbc) > 0) {
+        // 10 bytes of event header plus the 2-byte descriptor loop length; a
+        // shorter tail would be read past its end below
+        while (bytestream2_get_bytes_left(&ngbc) >= 12) {
             uint16_t descriptors_loop_length;
 
-            bytestream2_skip(&ngbc, (16 + 40 + 24) / 8);
+            bytestream2_skipu(&ngbc, (16 + 40 + 24) / 8);
             descriptors_loop_length =
                 bytestream2_get_be16u(&ngbc) & 0b0000111111111111;
 
@@ -1400,7 +1404,15 @@ emit_packet(MMTPContext *ctx, struct Streams *st, uint8_t *data, int size)
         }
         st->parser->fetch_timestamp = true;
 
-        av_assert0(ctx->pkt->data == NULL);
+        // An MFU carries a single access unit, so the parser should yield one
+        // frame per read; if a non-conformant MFU yields more, keep the first
+        // and warn rather than aborting on an assert.
+        if (ctx->pkt->data != NULL) {
+            av_log(ctx->s, AV_LOG_WARNING,
+                   "pid 0x%04x: parser produced more than one frame for a "
+                   "single MFU; dropping the extra frame\n", ctx->current_pid);
+            break;
+        }
         ctx->pkt->data = (uint8_t *) out_data;
         ctx->pkt->size = out_size;
 
@@ -1430,22 +1442,29 @@ static int consume_mfu(MMTPContext *ctx, GetByteContext *gbc)
     case AV_CODEC_ID_HEVC:
         size = bytestream2_get_be32(gbc);
         if (size != bytestream2_get_bytes_left(gbc)) return AVERROR_INVALIDDATA;
-        if ((buf = av_malloc(size + 3)) == NULL) return AVERROR(ENOMEM);
+        // ff_combine_frame reads AV_INPUT_BUFFER_PADDING_SIZE bytes past the
+        // data, so allocate and zero that padding; otherwise it reads
+        // adjacent heap.
+        if ((buf = av_malloc(size + 3 + AV_INPUT_BUFFER_PADDING_SIZE)) == NULL)
+            return AVERROR(ENOMEM);
         buf[0] = 0x00;
         buf[1] = 0x00;
         buf[2] = 0x01;
         bytestream2_get_bufferu(gbc, buf + 3, size);
+        memset(buf + 3 + size, 0, AV_INPUT_BUFFER_PADDING_SIZE);
         err = emit_packet(ctx, st, buf, size + 3);
         av_free(buf);
         return err;
     case AV_CODEC_ID_AAC_LATM:
         size = bytestream2_get_bytes_left(gbc);
         if (size >> 13) return AVERROR(EOVERFLOW);
-        if ((buf = av_malloc(size + 3)) == NULL) return AVERROR(ENOMEM);
+        if ((buf = av_malloc(size + 3 + AV_INPUT_BUFFER_PADDING_SIZE)) == NULL)
+            return AVERROR(ENOMEM);
         buf[0] = 0x56;
         buf[1] = 0xe0 | (size >> 8);
         buf[2] = size & 0xff;
         bytestream2_get_bufferu(gbc, buf + 3, size);
+        memset(buf + 3 + size, 0, AV_INPUT_BUFFER_PADDING_SIZE);
         err = emit_packet(ctx, st, buf, size + 3);
         av_free(buf);
         return err;
diff --git a/libavformat/mmttlv.c b/libavformat/mmttlv.c
index 04695a3..db769fc 100644
--- a/libavformat/mmttlv.c
+++ b/libavformat/mmttlv.c
@@ -78,10 +78,9 @@ static int mmttlv_probe(const AVProbeData *p)
                 i += data_length;
             }
         } else if (packet_type == NULL_PACKET) {
-            if (data_length < 1) goto skip;
             // null packets should contain all 0xFFs
-            for (j = i; j < i + data_length; ++j) {
-                if (j >= p->buf_size || p->buf[j] != 0xFF) goto skip;
+            for (j = i; j < i + data_length && j < p->buf_size; ++j) {
+                if (p->buf[j] != 0xFF) goto skip;
             }
             ++recognized;
             i += data_length;
@@ -102,6 +101,7 @@ struct MMTTLVContext {
 
     int64_t last_pos;
     size_t  resync_size;
+    int     resync_fails;  // consecutive exhausted hunts; bounds the REDO retries
 
     size_t  cap;
     uint8_t *buf;
@@ -162,12 +162,16 @@ static int mmttlv_read_compressed_ip_packet(
 
     if (program == NULL) {
         AVProgram *p = av_new_program(s, context_id);
-        if (p == NULL) return AVERROR(errno);
+        if (p == NULL) return AVERROR(ENOMEM);
 
         program = av_malloc(sizeof(struct Program));
-        if (program == NULL) return AVERROR(errno);
+        if (program == NULL) return AVERROR(ENOMEM);
 
         program->mmtp = ff_mmtp_parse_open(p);
+        if (program->mmtp == NULL) {
+            av_free(program);
+            return AVERROR(ENOMEM);
+        }
         program->next = ctx->programs;
         ctx->programs = program;
         program->cid  = context_id;
@@ -191,6 +195,13 @@ static int mmttlv_read_compressed_ip_packet(
     return ff_mmtp_parse_packet(program->mmtp, s, pkt, buf, size);
 }
 
+static int mmttlv_valid_type(uint8_t t)
+{
+    return t == IPV4_PACKET || t == IPV6_PACKET ||
+           t == HEADER_COMPRESSED_IP_PACKET ||
+           t == TRANSMISSION_CONTROL_PACKET || t == NULL_PACKET;
+}
+
 static int mmttlv_read_packet(AVFormatContext *s, AVPacket *pkt)
 {
     uint8_t              header[4];
@@ -204,48 +215,68 @@ static int mmttlv_read_packet(AVFormatContext *s, AVPacket *pkt)
         ctx->last_pos = pos;
 
         while (pos - ctx->last_pos < ctx->resync_size) {
+            int     valid, k;
+            int64_t next;
+
             if ((err = ffio_ensure_seekback(s->pb, 4)) < 0)
                 return err;
 
             if ((err = avio_read(s->pb, header, 4)) < 0)
                 return avio_feof(s->pb) ? AVERROR_EOF : err;
 
-            if (header[0] != HEADER_BYTE) {
+            if (header[0] != HEADER_BYTE || !mmttlv_valid_type(header[1])) {
                 if ((pos = avio_seek(s->pb, -3, SEEK_CUR)) < 0)
                     return (int) pos;
                 continue;
             }
 
-            size = AV_RB16(header + 2);
-
             if ((pos = avio_seek(s->pb, -4, SEEK_CUR)) < 0)
                 return (int) pos;
 
-            if ((err = ffio_ensure_seekback(s->pb, 4 + size + 1)) < 0)
+            // A header byte with a defined type recurs freely in coded
+            // payloads; accept a candidate only if its length chain reaches
+            // two more valid headers (or the end of file), which makes a
+            // false accept vanishingly unlikely.
+            if ((err = ffio_ensure_seekback(
+                s->pb, 4 + AV_RB16(header + 2) + 4 + 0xFFFF + 4)) < 0)
                 return err;
 
-            if ((pos = avio_skip(s->pb, 4 + size)) < 0)
-                return (int) pos;
-
-            if ((err = avio_read(s->pb, header, 1)) < 0)
-                return avio_feof(s->pb) ? AVERROR_EOF : err;
+            valid = 1;
+            next  = pos;
+            for (k = 0; k < 2; k++) {
+                next += 4 + AV_RB16(header + 2);
+                if (avio_seek(s->pb, next, SEEK_SET) < 0)
+                    break;
+                err = avio_read(s->pb, header, 4);
+                if (err < 4) {
+                    if (err < 0 && !avio_feof(s->pb))
+                        return err;
+                    break; // clean end of file inside the chain
+                }
+                if (header[0] != HEADER_BYTE || !mmttlv_valid_type(header[1])) {
+                    valid = 0;
+                    break;
+                }
+            }
 
-            if (header[0] == HEADER_BYTE) {
-                // found HEADER, [size], HEADER, should be good
-                if ((pos = avio_seek(
-                    s->pb, -(int64_t) (size) - 1 - 4, SEEK_CUR)) < 0)
-                    return (int) pos;
+            if ((pos = avio_seek(s->pb, pos, SEEK_SET)) < 0)
+                return (int) pos;
+            if (valid)
                 goto success;
-            }
 
-            if ((pos = avio_seek(
-                s->pb, -(int64_t) (size) - 1 - 3, SEEK_CUR)) < 0)
+            if ((pos = avio_seek(s->pb, pos + 1, SEEK_SET)) < 0)
                 return (int) pos;
         }
+        // The hunt advanced by a whole window, so a retry makes progress; a
+        // hard error would let a caller's consecutive-error cap turn one bad
+        // spot into EOF.
+        if (++ctx->resync_fails <= 32)
+            return FFERROR_REDO;
         return AVERROR_INVALIDDATA;
 
         success:
-        ctx->last_pos = pos;
+        ctx->resync_fails = 0;
+        ctx->last_pos     = pos;
 
         for (struct Program *program = ctx->programs;
              program != NULL; program = program->next)
@@ -268,9 +299,14 @@ static int mmttlv_read_packet(AVFormatContext *s, AVPacket *pkt)
     }
 
     if (ctx->cap < size) {
-        av_free(ctx->buf);
-        if ((ctx->buf = av_malloc(ctx->cap = size)) == NULL)
-            return AVERROR(errno);
+        // Reset cap before allocating: on failure buf is NULL, and a stale
+        // cap == size would make a later call skip the realloc and read into
+        // NULL.
+        av_freep(&ctx->buf);
+        ctx->cap = 0;
+        if ((ctx->buf = av_malloc(size)) == NULL)
+            return AVERROR(ENOMEM);
+        ctx->cap = size;
     }
     if ((err = ffio_read_size(s->pb, ctx->buf, size)) < 0)
         return avio_feof(s->pb) ? AVERROR_EOF : err;
@@ -281,8 +317,12 @@ static int mmttlv_read_packet(AVFormatContext *s, AVPacket *pkt)
         return mmttlv_read_ipv6_packet(ctx, s, pkt, ctx->buf, size);
     case HEADER_COMPRESSED_IP_PACKET:
         return mmttlv_read_compressed_ip_packet(ctx, s, pkt, ctx->buf, size);
+    case TRANSMISSION_CONTROL_PACKET:
+        return pkt == NULL ? 0 : FFERROR_REDO;
     default:
-        return AVERROR_PATCHWELCOME;
+        av_log(s, AV_LOG_INFO,
+               "unsupported TLV packet type 0x%02x\n", header[1]);
+        return pkt == NULL ? 0 : FFERROR_REDO;
     }
 }
 
@@ -309,7 +349,7 @@ static int mmttlv_read_header(AVFormatContext *s)
     while (s->nb_streams <= 0 && allow > 0) {
         const int64_t cur = ctx->last_pos;
         const int     err = mmttlv_read_packet(s, NULL);
-        if (err < 0) return err;
+        if (err < 0 && err != FFERROR_REDO) return err;
         allow -= ctx->last_pos - cur;
     }
 
-- 
