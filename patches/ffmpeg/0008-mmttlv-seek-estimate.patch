From 2c5e618b7a16b598c3270d106b9cf90fb1d4dd0b Mon Sep 17 00:00:00 2001
From: Rainbaby <rainbaby@outlook.jp>
Date: Mon, 6 Jul 2026 20:02:28 +0900
Subject: [PATCH 3/3] avformat/mmttlv: seek by byte-position estimate, not a
 timestamp search

The timestamp binary search reset state, re-acquired signaling and reassembled
a whole access unit per probe, reading tens of MB on 4K/8K and collapsing far
seeks. MMT is close to constant bitrate, so estimate the byte offset from
duration, back off two seconds to land before the target, and resync forward.
Seeks that stalled for minutes now land within about a second.

Signed-off-by: Rainbaby <rainbaby@outlook.jp>
---
 libavformat/mmttlv.c | 30 +++++++++++++++++++++++++++++-
 1 file changed, 29 insertions(+), 1 deletion(-)

diff --git a/libavformat/mmttlv.c b/libavformat/mmttlv.c
index 1b3eb01..95870fa 100644
--- a/libavformat/mmttlv.c
+++ b/libavformat/mmttlv.c
@@ -23,6 +23,7 @@
 
 #include "libavutil/mem.h"
 #include "libavutil/intreadwrite.h"
+#include "libavutil/mathematics.h"
 #include "avformat.h"
 #include "avio_internal.h"
 #include "demux.h"
@@ -521,6 +522,33 @@ static int64_t mmttlv_read_timestamp(
     return result;
 }
 
+// Seek by estimating the byte position from duration. The timestamp binary search re-acquires
+// signaling and reassembles a whole access unit per probe, which on 4K/8K reads tens of MB and
+// collapses. MMT runs at close to constant bitrate, so map the target time onto the file
+// linearly, back off a couple of seconds to land before it, and resync forward from there.
+static int mmttlv_read_seek(AVFormatContext *s, int stream_index,
+                            int64_t timestamp, int flags)
+{
+    struct MMTTLVContext *ctx = s->priv_data;
+    AVStream             *st  = s->streams[stream_index];
+    int64_t file_size = avio_size(s->pb);
+    int64_t ts_us, bytes_per_sec, pos;
+
+    if (file_size <= 0 || s->duration <= 0)
+        return AVERROR(ENOSYS);
+
+    ts_us         = av_rescale_q(timestamp, st->time_base, AV_TIME_BASE_Q);
+    ts_us         = av_clip64(ts_us, 0, s->duration);
+    bytes_per_sec = av_rescale(file_size, AV_TIME_BASE, s->duration);
+    pos           = av_rescale(ts_us, file_size, s->duration) - 2 * bytes_per_sec;
+    pos           = av_clip64(pos, 0, file_size - 1);
+
+    if ((pos = avio_seek(s->pb, pos, SEEK_SET)) < 0)
+        return (int) pos;
+    ctx->last_pos = -1; // force resync + state reset at the new position
+    return 0;
+}
+
 #if CONFIG_MMTTLV_DEMUXER
 const FFInputFormat ff_mmttlv_demuxer = {
     .p.name         = "mmttlv",
@@ -534,6 +562,6 @@ const FFInputFormat ff_mmttlv_demuxer = {
     .read_packet    = mmttlv_read_packet,
     .read_close     = mmttlv_read_close,
     .read_timestamp = mmttlv_read_timestamp,
-    .read_seek      = ff_seek_frame_binary,
+    .read_seek      = mmttlv_read_seek,
 };
 #endif
