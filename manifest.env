# Pinned build inputs for mpv-builds. Human-readable record; keep in sync with
# .github/workflows/build.yml (the workflow currently reads these from its own env).
#
# We build mpv (the player app: mpv.app on macOS, mpv.exe on Windows, the binary on Linux)
# against an FFmpeg compiled from source with the patches under patches/ffmpeg/ applied; today
# the MMT/TLV demuxer (ARIB STD-B32), so mpv plays Japanese ISDB-S3 4K/8K .mmts files natively.

FFMPEG_VERSION=8.0.1        # FFmpeg release the patches/ffmpeg/*.patch target (base 8.0, 8.0.1 compatible)
MPV_REF=master             # mpv git ref to build (master = nightly); pin a tag for a stable build
CACHE_EPOCH=1              # bump to force a full FFmpeg+mpv rebuild (busts the deps cache)
