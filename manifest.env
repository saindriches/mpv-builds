# Pinned build inputs for mpv-builds. Human-readable record; keep in sync with
# .github/workflows/build.yml (the workflow currently reads these from its own env).
#
# We build mpv (the player app: mpv.app on macOS, mpv.exe on Windows, the binary on Linux)
# against an FFmpeg compiled from our MMT/TLV fork branch (saindriches/FFmpeg @ mmt-tlv): that
# branch carries the MMT/TLV demuxer (ARIB STD-B32) in-tree, so mpv plays Japanese ISDB-S3 4K/8K
# .mmts files natively. (Previously the feature was carried as patches/ffmpeg/*.patch on a release
# tarball; the fork branch supersedes them. mpv's own source patches still live in patches/mpv/.)

FFMPEG_REPO=saindriches/FFmpeg                              # MMT/TLV FFmpeg fork (base FFmpeg 8.0)
FFMPEG_REF=90b4ce9b379ccd56d2c7536681df7bd2b2a0bf9b         # mmt-tlv branch head; bump to re-sync
MPV_REF=master             # mpv git ref to build (master = nightly); pin a tag for a stable build
CACHE_EPOCH=1              # bump to force a full FFmpeg+mpv rebuild (busts the deps cache)
